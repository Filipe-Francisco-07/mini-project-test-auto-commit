{
  "name": "DocGen Notifications",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "docgen",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "docgen-webhook"
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "operation": "equal",
              "value1": "={{ $json.body.event }}",
              "value2": "push"
            },
            {
              "operation": "equal",
              "value1": "={{ $json.body.event }}",
              "value2": "test_result"
            },
            {
              "operation": "equal",
              "value1": "={{ $json.body.event }}",
              "value2": "docs_generated"
            }
          ]
        }
      },
      "id": "switch-event",
      "name": "Tipo de Evento",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [480, 300]
